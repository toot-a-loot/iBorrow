@{
    ViewData["Title"] = "Borrowing";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/borrowing.css" asp-append-version="true" />
}

<!-- ===================================================
     Hero Section
     =================================================== -->
<section class="borrow-hero" aria-label="Borrow Books Hero">
    <div class="borrow-hero__overlay"></div>
    <div class="borrow-hero__content">
        <h1 class="borrow-hero__heading">Borrow Books.</h1>
        <p class="borrow-hero__subtitle">Discover available books</p>
    </div>
</section>

<!-- ===================================================
     Search Section
     (Floats over the hero via negative margin)
     =================================================== -->
<section class="search-section" aria-label="Book Search">
    <div class="container">
        <div class="search-panel">

            <!-- Search Form -->
            <form method="get" action="" role="search" aria-label="Search books">

                <!-- First Row: Search Input + Buttons -->
                <div class="search-panel__row search-panel__row--primary">
                    <div class="search-panel__input-wrapper">
                        <span class="search-panel__icon" aria-hidden="true">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="search" id="searchInput" name="search" class="search-panel__input"
                               placeholder="Search by title, author, or keyword"
                               aria-label="Search by title, author, or keyword" autocomplete="off" />
                    </div>

                    <div class="search-panel__actions">
                        <button type="submit" id="searchBtn" class="btn-search" aria-label="Search books">
                            Search
                        </button>

                        <button type="button" id="advancedFiltersBtn" class="btn-filters"
                                aria-label="Show advanced filters" aria-expanded="false" aria-controls="advancedFilters">
                            <i class="bi bi-sliders" aria-hidden="true"></i>
                            Advanced Filters
                        </button>
                    </div>
                </div>

                <!-- Divider -->
                <hr class="search-panel__divider" />

                <!-- Second Row: Dropdown Filters -->
                <!-- Future: bind to Model.CategoryId, Model.AuthorId, Model.SortBy -->
                <div class="search-panel__row search-panel__row--filters" id="advancedFilters">

                    <!-- Category Dropdown -->
                    <div class="filter-group">
                        <label for="categorySelect" class="filter-group__label">Category</label>
                        <select id="categorySelect" name="categoryId" class="filter-group__select"
                                aria-label="Filter by category">
                            <!-- Future: <option value="">All Categories</option> -->
                            @* <!-- Future: @foreach(var cat in Model.Categories) {
                            <option value="@cat.Id">@cat.Name</option>
                            }
 --> *@
                            <option value="">All Categories</option>
                            <option value="1">Fiction</option>
                            <option value="2">Non-Fiction</option>
                            <option value="3">Science</option>
                            <option value="4">History</option>
                            <option value="5">Technology</option>
                            <option value="6">Biography</option>
                            <option value="7">Philosophy</option>
                        </select>
                    </div>

                    <!-- Author Dropdown -->
                    <div class="filter-group">
                        <label for="authorSelect" class="filter-group__label">Author</label>
                        <select id="authorSelect" name="authorId" class="filter-group__select"
                                aria-label="Filter by author">
                            <!-- Future: <option value="">All Authors</option> -->
                            @* <!-- Future: @foreach(var author in Model.Authors) {
                            <option value="@author.Id">@author.Name</option>
                            } --> *@
                            <option value="">All Authors</option>
                            <option value="1">George Orwell</option>
                            <option value="2">J.K. Rowling</option>
                            <option value="3">Haruki Murakami</option>
                            <option value="4">Stephen King</option>
                            <option value="5">Agatha Christie</option>
                        </select>
                    </div>

                    <!-- Sort By Dropdown -->
                    <div class="filter-group">
                        <label for="sortBySelect" class="filter-group__label">Sort by</label>
                        <select id="sortBySelect" name="sortBy" class="filter-group__select"
                                aria-label="Sort results by">
                            <!-- Future: selected based on Model.SortBy -->
                            <option value="newest">Newest First</option>
                            <option value="oldest">Oldest First</option>
                            <option value="az">A–Z</option>
                            <option value="za">Z–A</option>
                            <option value="available">Available First</option>
                        </select>
                    </div>

                </div>
                <!-- /Second Row -->

            </form>
            <!-- /Search Form -->

        </div>
        <!-- /search-panel -->
    </div>
</section>
<!-- /Search Section -->

