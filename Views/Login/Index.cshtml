@model iBorrow.Models.LoginViewModel

@{ ViewData["Title"] = "Login"; }

@section Styles {
    <link rel="stylesheet" href="~/css/pages/login.css" asp-append-version="true" />
}

<section class="login-page">
    <div class="login-shell">
        <div class="login-form-panel">
            <div class="login-branding">
                <img src="~/images/iborrowLogo.svg" alt="iBorrow logo" class="login-brand-logo" />
                <div class="login-brand-text">
                    <span class="login-brand-title">iBorrow</span>
                    <span class="login-brand-subtitle">Library System</span>
                </div>
            </div>

            <div class="login-card">
                @if (ViewBag.SuccessMessage != null)
                {
                    <div class="alert alert-success" role="alert">
                        @ViewBag.SuccessMessage
                    </div>
                }

                <form asp-action="Index" asp-controller="Login" method="post" class="login-form" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                    <div class="form-field">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" placeholder="name@school.edu" autofocus />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="form-field">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control" placeholder="Enter your password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="login-submit">Login</button>

                    <p class="login-signup-link">
                        Don't have an account?
                        <a asp-controller="Registration" asp-action="Index">Sign up</a>
                    </p>
                </form>
            </div>
        </div>

        <div class="login-image-panel" role="presentation" aria-hidden="true"></div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
