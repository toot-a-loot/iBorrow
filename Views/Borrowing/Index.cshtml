                    <a href="#" class="pagination-list__link" aria-label="Go to page 3">
                        3
                    </a>
                </li>

                <!-- Ellipsis -->
                <!-- Future: render when total pages exceed visible window -->
                <li class="pagination-list__item pagination-list__item--ellipsis" aria-hidden="true">
                    <span class="pagination-list__ellipsis">...</span>
                </li>

                <!-- Last Page -->
                @* <!-- Future: @Model.TotalPages --> *@
                <li class="pagination-list__item">
                    <a href="#" class="pagination-list__link" aria-label="Go to last page, page 69">
                        69
                    </a>
                </li>

                <!-- Next Button -->
                <!-- Future: disabled when Model.CurrentPage == Model.TotalPages -->
                <li class="pagination-list__item">
                    <a href="#" class="pagination-list__link pagination-list__link--next" aria-label="Go to next page"
                       rel="next">
