<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - iBorrow</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/iBorrow.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="main-header">
        <div class="header-contents">
            <a class="brand" asp-area="" asp-controller="Home" asp-action="Index">
                <img src="~/images/iborrowlogo.svg" alt="iBorrow logo" class="brand-logo" />
                <span class="brand-text">
                    <span class="brand-name">iBorrow</span>
                    <span class="brand-tagline">Library System</span>
                </span>
            </a>

            <button class="nav-toggle" type="button" id="navToggle" aria-controls="siteNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <nav class="nav-main" id="siteNav">
                <a asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                <a asp-area="" asp-controller="Library" asp-action="Index">Library</a>
                <a asp-area="" asp-controller="Borrowing" asp-action="Index">Borrowing</a>
            </nav>

            <a href="#" class="btn-login">
                <img src="~/images/userIcon.svg" alt="" class="login-icon" aria-hidden="true" />
                Login
            </a>
        </div>
    </header>
    <main role="main" class="main-body">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>