        <!-- ===============================================
             Pagination
             Future: generate dynamically from Model.CurrentPage / Model.TotalPages
             =============================================== -->
        <nav class="pagination-nav" aria-label="Book results pagination">
            <ul class="pagination-list">

                <!-- Previous Button -->
                <!-- Future: disabled when Model.CurrentPage == 1 -->
                <li class="pagination-list__item">
                    <a href="#" class="pagination-list__link pagination-list__link--prev"
                       aria-label="Go to previous page" rel="prev">
                        <i class="bi bi-chevron-left" aria-hidden="true"></i>
                    </a>
                </li>

                <!-- Page 1 — Active (current page) -->
                @* <!-- Future: class="pagination-list__link pagination-list__link--active" when @page ==
                Model.CurrentPage --> *@
                <li class="pagination-list__item">
                    <a href="#" class="pagination-list__link pagination-list__link--active"
                       aria-label="Page 1, current page" aria-current="page">
                        1
                    </a>
                </li>

                <!-- Page 2 -->
                <li class="pagination-list__item">
                    <a href="#" class="pagination-list__link" aria-label="Go to page 2">
                        2
                    </a>
                </li>

                <!-- Page 3 -->
